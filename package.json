{
  "name": "@sds-smith/liquid-glass-ui",
  "version": "1.0.5",
  "description": "A React UI library for building liquid glass interfaces.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "liquid-glass",
    "ui",
    "react",
    "library"
  ],
  "author": "Shawn D Smith",
  "license": "ISC",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/@sds-smith"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --minify",
    "test": "npm run type-check && npm run build-verify",
    "type-check": "tsc --noEmit",
    "build-verify": "tsc && ls dist/index.d.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-avatar": "^1.0.0",
    "@radix-ui/react-collapsible": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.0",
    "@radix-ui/react-tabs": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
