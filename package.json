{
  "name": "@metamatopoeia/liquid-glass-ui",
  "version": "1.2.4",
  "description": "A React UI library for building liquid glass interfaces.",
  "author": "Shawn D Smith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/metamatopoeia/liquid-glass-ui.git"
  },
  "bugs": {
    "url": "https://github.com/metamatopoeia/liquid-glass-ui/issues"
  },
  "homepage": "https://github.com/metamatopoeia/liquid-glass-ui#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "liquid-glass",
    "ui",
    "react",
    "library",
    "design-system"
  ],
  "sideEffects": [
    "./dist/index.css",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --minify",
    "test": "npm run type-check",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build",
    "version": "npm version $npm_package_version --prefix mcp-server --no-git-tag-version && git add mcp-server/package.json",
    "postversion": "npm publish && npm publish mcp-server"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.0.0",
    "@radix-ui/react-avatar": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
