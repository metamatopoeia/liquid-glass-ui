{
  "name": "liquid-glass-ui-monorepo",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "release:version": "changeset version && node scripts/sync-mcp-version.js && git add packages/mcp-server/package.json",
    "release": "turbo run build && changeset publish --provenance"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "turbo": "^2.0.0"
  }
}
