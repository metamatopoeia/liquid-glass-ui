{
  "name": "@metamatopoeia/liquid-glass-core",
  "version": "1.4.0",
  "description": "Shared types, tokens, and utilities for Liquid Glass UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metamatopoeia/liquid-glass-ui.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --minify",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
